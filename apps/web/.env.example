# Variaveis publicas do Vite (somente prefixo VITE_ entra no bundle do frontend).
# SECURITY.md: nada de segredo aqui - chaves de API ficam no backend (apps/api/.env).

# URL base do backend Fastify (REST + WebSocket).
# Em desenvolvimento o backend sobe em http://localhost:3000.
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/ws

# DSN do Sentry para captura de erros no navegador (ROADMAP.md MVP - Sentry basico).
# Vazio em dev/test/CI - lib/sentry.ts faz noop e nao instala handlers.
# Em producao: copiar do painel do Sentry (Settings > Projects > <projeto> > Client Keys).
# DSN do Sentry eh publico por design (so envia eventos, nao le dados) - pode entrar no bundle.
VITE_SENTRY_DSN=
