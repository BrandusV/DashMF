# Variaveis de ambiente do backend Fastify.
# SECURITY.md secao 2: NUNCA commitar valores reais. Este arquivo documenta
# apenas os NOMES das chaves esperadas - producao injeta via painel do
# provedor (Railway), CI usa GitHub Secrets, dev local copia para .env.

# Ambiente de execucao - 'development' | 'production' | 'test'.
NODE_ENV=development

# Porta HTTP do Fastify. 0 = ephemeral (usado em testes).
PORT=3000

# URL do frontend autorizada no CORS (SECURITY.md secao 3).
# Em producao: dominio da Vercel. NUNCA usar '*' em producao.
FRONTEND_URL=http://localhost:5173

# === Adapters de cotacoes (DATA_GOVERNANCE.md) ===
# ExchangeRate-API: chave gratuita em exchangerate-api.com.
EXCHANGE_RATE_API_KEY=
# Open Exchange Rates: app_id (plano free).
OPEN_EXCHANGE_RATES_APP_ID=

# === Adapters de noticias (DATA_GOVERNANCE.md) ===
NEWS_API_KEY=
GNEWS_API_KEY=

# === Persistencia (V1+ do roadmap; opcional no MVP) ===
# Postgres com TLS - SECURITY.md secao 5 exige sslmode=require em producao.
DATABASE_URL=
# Redis para cache de cotacoes (CacheService usa stub se ausente).
REDIS_URL=

# === Auth (V2 do roadmap) ===
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === Observabilidade (ROADMAP.md MVP - Sentry basico) ===
# DSN do Sentry para captura de erros no servidor.
# Vazio em dev/test/CI - lib/sentry.ts faz noop nesse caso.
# Producao: copiar do painel do Sentry (Settings > Projects > <projeto> > Client Keys).
SENTRY_DSN=
